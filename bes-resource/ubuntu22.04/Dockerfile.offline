#
# 离线构建 Dockerfile - 保持与原始 Dockerfile 一致，仅修改在线资源加载方式
#

FROM quay.io/ascend/cann:9.0.0-910b-ubuntu22.04-py3.11

ARG PIP_INDEX_URL="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple"
ARG MOONCAKE_TAG="v0.3.8.post1"

WORKDIR /workspace

# 复制所有离线 pip 包到统一目录
COPY bes-resource/ubuntu22.04/offline-resource/pip/ /tmp/pip-all/

# 复制离线 apt 包和 Mooncake 依赖
COPY bes-resource/ubuntu22.04/offline-resource/apt/ /tmp/apt-packages/
COPY bes-resource/ubuntu22.04/offline-resource/mooncake-deps/ /vllm-workspace/mooncake-deps/
COPY bes-resource/ubuntu22.04/offline-resource/changecode/Mooncake/mooncake_installer_offline.sh /vllm-workspace/mooncake_installer_offline.sh

# Install clang-15 (for triton-ascend) and Mooncake
# 原始: apt-get update -y && apt-get install -y ...
# 离线: 从本地目录安装 deb 包，然后 apt-get install 补充缺失的包
RUN apt-get update -y && \
    cd /tmp/apt-packages && \
    dpkg -i *.deb 2>/dev/null || true && \
    apt-get install -f -y && \
    apt-get install -y git vim wget net-tools gcc g++ cmake numactl libnuma-dev libjemalloc2 clang-15 && \
    update-alternatives --install /usr/bin/clang clang /usr/bin/clang-15 20 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-15 20 && \
    rm -rf /tmp/apt-packages && \
    rm -rf /var/cache/apt/* && \
    rm -rf /var/lib/apt/lists/*

# 复制 Mooncake 代码和 mooncake_installer_offline.sh
COPY bes-resource/ubuntu22.04/offline-resource/code/Mooncake/ /vllm-workspace/Mooncake/
COPY bes-resource/ubuntu22.04/offline-resource/changecode/Mooncake/mooncake_installer_offline.sh /vllm-workspace/Mooncake/mooncake_installer.sh

# 执行 Mooncake 安装和构建
RUN cd /vllm-workspace/Mooncake && \
    mv mooncake_installer_offline.sh mooncake_installer.sh 2>/dev/null || true && \
    export OFFLINE_DEPS_DIR=/vllm-workspace/mooncake-deps && \
    bash mooncake_installer.sh -y && \
    ARCH=$(uname -m) && \
    source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    export LD_LIBRARY_PATH=/usr/local/Ascend/ascend-toolkit/latest/${ARCH}-linux/devlib:/usr/local/Ascend/ascend-toolkit/latest/${ARCH}-linux/lib64:$LD_LIBRARY_PATH && \
    mkdir -p build && cd build && cmake .. -DUSE_ASCEND_DIRECT=ON && \
    make -j$(nproc) && make install && \
    rm -rf /vllm-workspace/Mooncake/build && \
    rm -rf /vllm-workspace/mooncake-deps

# Install modelscope (for fast download) and ray (for multinode)
RUN pip config set global.index-url ${PIP_INDEX_URL} && \
    python3 -m pip install --find-links=/tmp/pip-all/common --find-links=/tmp/pip-all/vllm --find-links=/tmp/pip-all/vllm-ascend \
    modelscope 'ray>=2.47.1,<=2.48.0' 'protobuf>3.20.0' && \
    python3 -m pip cache purge

# Install vLLM
ARG VLLM_REPO=https://github.com/vllm-project/vllm.git
ARG VLLM_TAG=v0.20.2
COPY bes-resource/ubuntu22.04/offline-resource/code/vllm/ /vllm-workspace/vllm/

# 先安装构建依赖，再安装 vllm
RUN VLLM_TARGET_DEVICE="empty" python3 -m pip install --find-links=/tmp/pip-all/vllm --find-links=/tmp/pip-all/vllm-ascend --find-links=/tmp/pip-all/common \
    cmake wheel setuptools-scm packaging && \
    python3 -m pip install --find-links=/tmp/pip-all/vllm --find-links=/tmp/pip-all/common \
    -e /vllm-workspace/vllm/[audio] && \
    python3 -m pip uninstall -y triton && \
    python3 -m pip cache purge

# Install vllm-ascend
ARG SOC_VERSION="ascend910b1"
ARG COMPILE_CUSTOM_KERNELS=1
ENV DEBIAN_FRONTEND=noninteractive
ENV SOC_VERSION=$SOC_VERSION \
    TASK_QUEUE_ENABLE=1 \
    OMP_NUM_THREADS=1
COPY . /vllm-workspace/vllm-ascend/

RUN export PIP_EXTRA_INDEX_URL="https://mirrors.huaweicloud.com/ascend/repos/pypi" && \
    source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    source /usr/local/Ascend/nnal/atb/set_env.sh && \
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/Ascend/ascend-toolkit/latest/`uname -i`-linux/devlib && \
    # 先安装构建依赖
    python3 -m pip install --find-links=/tmp/pip-all/vllm-ascend --find-links=/tmp/pip-all/common \
    cmake wheel setuptools-scm packaging googleapis-common-protos && \
    # 安装 vllm-ascend
    python3 -m pip install --find-links=/tmp/pip-all/vllm-ascend --find-links=/tmp/pip-all/common \
    -e /vllm-workspace/vllm-ascend/ && \
    python3 -m pip uninstall -y triton triton-ascend && \
    python3 -m pip install --find-links=/tmp/pip-all/vllm-ascend triton-ascend==3.2.1 && \
    python3 -m pip cache purge && \
    rm -rf /tmp/pip-all

# Append `libascend_hal.so` path (devlib) to LD_LIBRARY_PATH
RUN echo "export LD_PRELOAD=/usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2:$LD_PRELOAD" >> ~/.bashrc
RUN echo "export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/lib" >> ~/.bashrc

CMD ["/bin/bash"]